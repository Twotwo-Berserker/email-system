# ============================================================
# 邮件系统 — 环境变量配置模板
# 使用说明: 复制此文件为 .env 并修改其中的值
#   cp .env.example .env
# ============================================================

# -------------------- MySQL 数据库 --------------------
# 【生产环境替换项】生产环境必须使用强密码，且不应使用 root 账号
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=mail_system
MYSQL_USER=mailuser
MYSQL_PASSWORD=mailpass123

# -------------------- Redis 缓存 --------------------
# 【生产环境替换项】生产环境必须使用强密码，建议 32 位以上随机字符串
REDIS_PASSWORD=redis_secure_password_2026
# Redis 最大内存限制
REDIS_MAXMEMORY=256mb

# -------------------- MinIO 对象存储 --------------------
# 【生产环境替换项】生产环境必须使用强密码，建议 32 位以上随机字符串
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# -------------------- JWT 认证 --------------------
# 【生产环境替换项】生产环境必须使用随机生成的密钥，长度至少 256 位
JWT_SECRET=mail-system-2026-secret-key-for-jwt-token-generation
# Token 有效期（毫秒），默认 24 小时 = 86400000
JWT_EXPIRATION=86400000

# -------------------- 文件上传限制 --------------------
# 附件上传大小限制（字节），默认 50MB
FILE_UPLOAD_MAX_SIZE=52428800
# 请求体大小限制（字节），需大于附件限制
FILE_REQUEST_MAX_SIZE=104857600

# -------------------- 服务端口配置 --------------------
# 以下端口可根据宿主机端口占用情况调整
NGINX_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
