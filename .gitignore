# ============================================================
# 邮件系统 — .gitignore
# 纯 Docker 部署模式，排除本地构建产物和敏感配置
# ============================================================

# -------------------- 环境配置（含敏感密码）--------------------
.env

# -------------------- 前端 --------------------
frontend/node_modules/
frontend/dist/

# -------------------- 后端 --------------------
backend/target/
backend/uploads/

# -------------------- 本地数据目录（Docker 卷替代）--------------------
data/

# -------------------- IDE 配置 --------------------
.idea/
.vscode/
*.iml
*.iws
*.ipr

# -------------------- 操作系统 --------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
